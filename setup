#!/bin/bash

# Description:
# This script will detect the system's OS, then apply the dotfile configs for that system type.

# Grabbing the OS type from the /etc/os-release file,
# scoping the shellcheck directive to only this function.
#
# If /etc/os-release does not exist, assumes macos
getOsType() {
  # This is only applicable on Linux machines.
  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    source /etc/os-release

    echo "${ID_LIKE}"
  else
    echo "macos"
  fi
}
OS_TYPE=$(getOsType)

# Grabbing the script's directory
SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "${SCRIPT_PATH}")"

# Shorthand function for checking if software is installed
isInstalled() {
  command -v "${1}" &>/dev/null
}

symLink() {
  local originPath="$1"
  local targetPath="$2"

  if [[ -f "${originPath}" ]]; then
    # Need to make sure there's a valid target to symlink
    [[ ! -f "${targetPath}" ]] && touch "${targetPath}"

    ln -sf "${originPath}" "${targetPath}"
  else
    echo "symLink: Invalid origin path: ${originPath}"
  fi
}

# Takes in origin directory and a target directory.
# Iterates through all files within origin directory and creates symLinks within the target directory.
symLinkDir() {
  local originDir="${1}"
  local targetDir="${2}"

  if [[ -d "${originDir}" ]]; then
    echo "Creating symLinks for ${originDir##*/} files.."

    # Making sure targetDir exists
    [[ ! -d "${targetDir}" ]] && mkdir -p "${targetDir}"

    for file in "${originDir}"/*; do
      local fileName="${file##*/}"
      symLink "${file}" "${targetDir}/${fileName}"
    done

    echo "Done." && echo ""
  else
    echo "symLinkDir: ERROR: Invalid originDir: ${originDir}"
  fi
}

# i3 Configs
if isInstalled i3; then
  echo "Creating symLinks for i3.."
  symLinkDir "${SCRIPT_DIR}/i3-wm" ~/.config/i3
fi

# Starship Configs
if isInstalled starship; then
  echo "Creating symLinks for starship.."
  symLink "${SCRIPT_DIR}/starship/starship.toml" ~/.config/starship.toml
  echo "NOTE: Starship requires adding \`eval \"\$(starship init bash)\"\` to your ~/.bashrc file"
  echo "Done." && echo ""
fi

# Tmux Configs
if isInstalled tmux; then
  echo "Creating symLinks for tmux.."
  symLink "${SCRIPT_DIR}/tmux/tmux.conf" ~/.tmux.conf
  echo "Done." && echo ""
fi

# Alacritty Configs
if isInstalled alacritty; then
  echo "Creating symLinks for alacritty.."
  [[ ! -d ~/.config/alacritty ]] && mkdir -p ~/.config/alacritty
  symLink "${SCRIPT_DIR}/alacritty/alacritty.toml" ~/.config/alacritty/alacritty.toml
  echo "Done." && echo ""
fi

# EDITOR to vim
if [[ "${EDITOR}" != "vim" ]]; then
  echo "Checking for EDITOR set to 'vim'.."
  echo "NOTE: Your current EDITOR is not set to vim."
  echo "Consider adding \`export EDITOR=vim\` to your ~/.bashrc"
  echo "Done." && echo ""
fi

# Vimrc Configs
if isInstalled vim; then
  echo "Creating symLinks for vimrc.."
  symLink "${SCRIPT_DIR}/vimrc/${OS_TYPE}-vimrc" ~/.vimrc
  echo "Done." && echo ""
fi

# NeoVim Configs
if isInstalled nvim; then
  echo "Creating symLinks for nvim.."

  HOME_NVIM="${HOME}/.config/nvim"
  HOME_PLUGINS="${HOME_NVIM}/lua/plugins"

  SCRIPT_NVIM="${SCRIPT_DIR}/nvim"
  SCRIPT_LUA="${SCRIPT_NVIM}/lua"
  SCRIPT_PLUGINS="${SCRIPT_LUA}/plugins"

  # Need to make sure the nvim config directory exists.
  [[ ! -d "${HOME_NVIM}" ]] && mkdir -p "${HOME_NVIM}"

  # Adding nvim directory files
  symLink "${SCRIPT_NVIM}/README.md" "${HOME_NVIM}/README.md"
  symLink "${SCRIPT_NVIM}/init.lua" "${HOME_NVIM}/init.lua"

  # Setting the configs
  symLinkDir "${SCRIPT_LUA}/config" "${HOME_NVIM}/lua/config"

  # Setting the plugins
  symLinkDir "${SCRIPT_PLUGINS}" "${HOME_PLUGINS}"
fi

# Claude-Code Configs
if isInstalled claude; then
  echo "Creating symLinks for Claude-Code.."
  [[ -d "${HOME}/.claude" ]] && symLink "${SCRIPT_DIR}/claude/CLAUDE.md" ~/.claude/CLAUDE.md
  echo "Done." && echo ""
fi

# Add personal scripts symlink
[[ ! -d "${HOME}/scripts" ]] && mkdir "${HOME}/scripts"
symLinkScripts() {
  echo "Creating symLinks for scripts.."
  for script in "${SCRIPT_DIR}"/scripts/*; do
    local scriptName="${script##*/}"
    symLink "${script}" ~/scripts/"${scriptName}"
    chmod +x "${script}"
  done
  echo "NOTE: Don't forget to add \`export PATH=\"\${HOME}/scripts:\${PATH}\"\` to your ~/.bashrc"
  echo "Done." && echo ""
}
symLinkScripts

# TODO: Add other dotfile configs as needed
